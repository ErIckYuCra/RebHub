# ─────────────────────────────────────────────────────────────
# ReadHub — Variables de entorno requeridas
# Copia este archivo como .env.local y completa los valores
# NUNCA subas .env.local a git
# ─────────────────────────────────────────────────────────────

# Supabase — disponibles en: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase — Service Role (SECRETO — solo para el servidor, nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# HuggingFace — disponible en: https://hf.co/settings/tokens
# Necesario para embeddings (all-MiniLM-L6-v2) y LLM (Llama-3.1-8B-Instruct)
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
